{
  "name": "nexsql-desktop",
  "version": "0.1.1",
  "description": "NexSQL - AI-Powered Database Client",
  "author": "NexSQL Allen.Zhang",
  "packageManager": "pnpm@10.33.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "node build/scripts/build-with-deploy.cjs --win",
    "build:mac": "node build/scripts/build-with-deploy.cjs --mac",
    "build:linux": "node build/scripts/build-with-deploy.cjs --linux",
    "build:win:direct": "set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& electron-vite build && electron-builder --win",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "electron-builder install-app-deps"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AllenZhanga/NexSQL.git"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-table": "^8.19.0",
    "@tanstack/react-virtual": "^3.10.0",
    "aws-ssl-profiles": "^1.1.2",
    "better-sqlite3": "^11.5.0",
    "denque": "^2.1.0",
    "event-target-shim": "^5.0.1",
    "generate-function": "^2.3.1",
    "iconv-lite": "^0.7.2",
    "clsx": "^2.1.0",
    "knex": "^3.0.0",
    "long": "^5.3.2",
    "lucide-react": "^0.460.0",
    "lru.min": "^1.1.4",
    "monaco-editor": "^0.52.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.11.0",
    "named-placeholders": "^1.1.6",
    "openai": "^4.77.0",
    "pg": "^8.13.0",
    "pg-connection-string": "^2.12.0",
    "pg-int8": "^1.0.1",
    "pg-pool": "^3.13.0",
    "pg-protocol": "^1.13.0",
    "pg-types": "^2.2.0",
    "pgpass": "^1.0.5",
    "postgres-array": "^2.0.0",
    "postgres-bytea": "^1.0.1",
    "postgres-date": "^1.0.7",
    "postgres-interval": "^1.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-resizable-panels": "^2.1.0",
    "split2": "^4.2.0",
    "sql-escaper": "^1.3.3",
    "tailwind-merge": "^2.5.0",
    "xtend": "^4.0.2",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/mssql": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
